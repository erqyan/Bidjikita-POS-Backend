# ── Dependencies ────────────────────────────────────────────────────────────
# Matches node_modules at any depth (root hoist + per-package)
node_modules/

# ── Environment variables ────────────────────────────────────────────────────
# Each package keeps its own .env; never commit secrets
.env
.env.local
.env.*.local
.env.keys

# ── Build output ─────────────────────────────────────────────────────────────
dashboard/dist/
api/dist/
dist/
build/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Runtime / OS ─────────────────────────────────────────────────────────────
pids/
*.pid
*.pid.lock
*.seed
coverage/
.cache/
.parcel-cache/
tmp/
temp/
.DS_Store
Thumbs.db

# ── Sequelize / uploads ──────────────────────────────────────────────────────
database.sqlite
api/uploads/

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
