// Prisma schema for Bidjikita POS
// MySQL database, auto-generated by mapping Sequelize models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ── Roles ────────────────────────────────────────────────────────────────────
model Role {
  id        Int    @id @default(autoincrement())
  role_name String @db.VarChar(255)
  users     User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("roles")
}

// ── Users ────────────────────────────────────────────────────────────────────
model User {
  id            Int       @id @default(autoincrement())
  full_name     String?   @db.VarChar(255)
  username      String    @unique @db.VarChar(255)
  password_hash String?   @db.VarChar(255)
  phone_number  String?   @db.VarChar(255)
  is_active     Boolean   @default(true)
  last_login    DateTime?
  role_id       Int?

  role          Role?           @relation(fields: [role_id], references: [id])
  orders        Order[]
  transactions  Transaction[]
  ingredientLogs IngredientLog[]

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("users")
}

// ── Categories ───────────────────────────────────────────────────────────────
model Category {
  id            Int       @id @default(autoincrement())
  category_name String    @unique @db.VarChar(255)
  description   String?   @db.Text

  products      Product[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("categories")
}

// ── Products ─────────────────────────────────────────────────────────────────
enum ProductStatus {
  available
  out_of_stock
}

model Product {
  id           Int             @id @default(autoincrement())
  product_name String          @unique @db.VarChar(255)
  description  String?         @db.Text
  image_url    String?         @db.Text
  status       ProductStatus   @default(available)
  is_active    Boolean         @default(true)
  category_id  Int?

  category     Category?       @relation(fields: [category_id], references: [id])
  variants     ProductVariant[]
  bundleItems  BundleItem[]
  orderDetails OrderDetail[]

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@map("products")
}

// ── Product Variants ─────────────────────────────────────────────────────────
model ProductVariant {
  id            Int       @id @default(autoincrement())
  variant_name  String    @db.VarChar(255)
  price         Decimal   @default(0) @db.Decimal(10, 2)
  overhead_cost Decimal   @default(0) @db.Decimal(10, 2)
  product_id    Int

  product       Product        @relation(fields: [product_id], references: [id], onDelete: Cascade)
  bundleItems   BundleItem[]
  ingredients   VariantIngredient[]
  orderDetailVariants OrderDetailVariant[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("product_variants")
}

// ── Variant Ingredients (bridge: variant ↔ raw material) ─────────────────────
model VariantIngredient {
  id              Int       @id @default(autoincrement())
  quantity        Decimal   @db.Decimal(10, 2)
  variant_id      Int
  raw_material_id Int

  variant         ProductVariant @relation(fields: [variant_id], references: [id], onDelete: Cascade)
  rawMaterial     RawMaterial    @relation(fields: [raw_material_id], references: [id])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("variantingredients")
}

// ── Raw Materials ────────────────────────────────────────────────────────────
model RawMaterial {
  id            Int       @id @default(autoincrement())
  material_name String    @unique @db.VarChar(255)
  unit          String    @db.VarChar(255)
  stock         Decimal   @default(0) @db.Decimal(10, 2)
  minimum_stock Decimal   @default(0) @db.Decimal(10, 2)
  cost_per_unit Decimal   @default(0) @db.Decimal(10, 4)

  ingredientLogs  IngredientLog[]
  variantIngredients VariantIngredient[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("rawmaterials")
}

// ── Ingredient Logs ──────────────────────────────────────────────────────────
enum ChangeType {
  manual_adjustment
  order_deduction
}

model IngredientLog {
  id              Int        @id @default(autoincrement())
  raw_material_id Int
  material_name   String?    @db.VarChar(255)
  previous_stock  Decimal    @db.Decimal(10, 2)
  new_stock       Decimal    @db.Decimal(10, 2)
  quantity_change Decimal    @db.Decimal(10, 2)
  change_type     ChangeType @default(manual_adjustment)
  user_id         Int?
  user_name       String?    @db.VarChar(255)
  notes           String?    @db.Text

  rawMaterial     RawMaterial @relation(fields: [raw_material_id], references: [id], onDelete: Cascade)
  user            User?       @relation(fields: [user_id], references: [id])

  createdAt       DateTime   @default(now())

  @@index([raw_material_id])
  @@map("ingredient_logs")
}

// ── Bundles ──────────────────────────────────────────────────────────────────
model Bundle {
  id               Int       @id @default(autoincrement())
  bundle_name      String    @unique @db.VarChar(255)
  description      String?   @db.Text
  image_url        String?   @db.Text
  bundle_price     Decimal   @db.Decimal(10, 2)
  total_bundle_cost Decimal  @default(0) @db.Decimal(10, 2)
  bundle_profit    Decimal?  @db.Decimal(10, 2)
  is_active        Boolean   @default(true)

  items            BundleItem[]
  orderDetails     OrderDetail[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("bundles")
}

// ── Bundle Items ─────────────────────────────────────────────────────────────
model BundleItem {
  id         Int     @id @default(autoincrement())
  bundle_id  Int
  product_id Int
  variant_id Int?
  quantity   Int

  bundle     Bundle           @relation(fields: [bundle_id], references: [id], onDelete: Cascade)
  product    Product          @relation(fields: [product_id], references: [id])
  variant    ProductVariant?  @relation(fields: [variant_id], references: [id], onDelete: SetNull)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("bundle_items")
}

// ── Orders ───────────────────────────────────────────────────────────────────
enum OrderStatus {
  pending
  completed
  cancelled
}

model Order {
  id            Int          @id @default(autoincrement())
  order_number  String       @unique @db.VarChar(255)
  total_amount  Decimal      @default(0) @db.Decimal(10, 2)
  order_status  OrderStatus  @default(pending)
  notes         String?      @db.Text
  user_id       Int?

  user          User?        @relation(fields: [user_id], references: [id])
  details       OrderDetail[]
  transaction   Transaction?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("orders")
}

// ── Order Details ────────────────────────────────────────────────────────────
model OrderDetail {
  id                Int      @id @default(autoincrement())
  quantity          Int
  price             Decimal  @db.Decimal(10, 2)
  subtotal          Decimal  @db.Decimal(10, 2)
  order_id          Int
  product_id        Int?
  bundle_id         Int?
  bundle_name       String?  @db.VarChar(255)
  bundle_items_json String?  @db.Text

  order             Order               @relation(fields: [order_id], references: [id])
  product           Product?            @relation(fields: [product_id], references: [id])
  bundle            Bundle?             @relation(fields: [bundle_id], references: [id])
  variantSelections OrderDetailVariant[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("order_details")
}

// ── Order Detail Variants ────────────────────────────────────────────────────
model OrderDetailVariant {
  id              Int          @id @default(autoincrement())
  order_detail_id Int
  variant_id      Int

  orderDetail     OrderDetail       @relation(fields: [order_detail_id], references: [id], onDelete: Cascade)
  variant         ProductVariant    @relation(fields: [variant_id], references: [id])

  @@map("orderdetailvariants")
}

// ── Transactions ─────────────────────────────────────────────────────────────
enum PaymentMethod {
  cash
  qris
  debit
  credit
}

enum PaymentStatus {
  pending
  paid
  failed
}

model Transaction {
  id               Int            @id @default(autoincrement())
  invoice_number   String         @unique @db.VarChar(255)
  transaction_date DateTime       @default(now())
  total_amount     Decimal        @db.Decimal(10, 2)
  payment_method   PaymentMethod
  payment_status   PaymentStatus  @default(paid)
  notes            String?        @db.Text
  order_id         Int?           @unique
  user_id          Int?

  order            Order?         @relation(fields: [order_id], references: [id])
  user             User?          @relation(fields: [user_id], references: [id])

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("transactions")
}
